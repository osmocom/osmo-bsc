# expect-no-chan
# meas-rep lchan 0 0 4 0 rxlev 40 rxqual 6 ta 0
# expect-ho from lchan 0 0 4 0 to lchan 0 0 1 0
expect-ts-use trx 0 0 states * TCH/F - - - - - -

